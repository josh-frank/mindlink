# =============================================================================
#  MindLink environment configuration
#  Copy this file to .env and fill in your values before running setup.sh:
#
#    cp .env.example .env
#    nano .env
#    PASSPHRASE=yourpassphrase sudo bash setup.sh
# =============================================================================

# ── Hotspot ───────────────────────────────────────────────────────────────────
SSID=MindLink
PASSPHRASE=                        # required — min 8 chars, no default
CHANNEL=6                          # 2.4 GHz channel (1, 6, or 11 recommended)

# ── Pi paths ──────────────────────────────────────────────────────────────────
MINDLINK_DIR=/home/pi/mindlink     # absolute path to the cloned repo
MINDLINK_USER=pi                   # user that mindlink.service runs as
